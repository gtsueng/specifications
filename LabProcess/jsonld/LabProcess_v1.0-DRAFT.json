                        }
                      ]
                    },
                    "valueReference": {
                      "oneOf": [
                        {
                          "@type": "DefinedTerm",
                          "type": "object",
                          "properties": {
                            "inDefinedTermSet": {
                              "type": "string"
                            },
                            "name": {
                              "type": "string"
                            },
                            "termcode": {
                              "type": "string"
                            },
