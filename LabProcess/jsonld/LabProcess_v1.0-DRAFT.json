                "required": [],
                "recommended": [
                      "name",
                      "propertyID",
                      "value",
                      "valueReference"
                    ],
                "optional": [
                      "unitCode",
                      "unitText"
                    ]
              },
              {
                "type": "array",
                "items": {
                  "@type": "PropertyValue",
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "value": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "boolean"
                        },
                        {
                          "type": "number"
                        }
                      ]
                    },
