                      {
                        "type": "string"
                      },
                      {
                        "type": "string",
                        "format": "uri"
                      }
                    ]
                  },
                  "valueReference": {
                    "oneOf": [
                      {
                        "@type": "DefinedTerm",
                        "type": "object",
                        "properties": {
                          "inDefinedTermSet": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "termcode": {
                            "type": "string"
                          },
                          "sameAs": {
                            "type": "string",
                            "format": "uri"
                          }
                        }
                      },
                      {
                        "type": "string"
                      }
                    ]
                  },
                  "unitCode": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "string",
                        "format": "uri"
                      }
                    ]
